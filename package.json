{
  "name": "bilibili-webos",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "icons:subset": "node ./scripts/generate-material-symbols-subset.mjs",
    "dev": "npm run icons:subset && vite",
    "build": "npm run icons:subset && tsc --noEmit && vite build",
    "build:webos": "node ./scripts/build-webos.mjs",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "relay:up": "docker compose --env-file relay/.env.local -f relay/compose.yaml up -d",
    "relay:down": "docker compose --env-file relay/.env.local -f relay/compose.yaml down",
    "relay:logs": "docker compose --env-file relay/.env.local -f relay/compose.yaml logs -f",
    "relay:ps": "docker compose --env-file relay/.env.local -f relay/compose.yaml ps",
    "verify:simulator-playback": "node ./scripts/verify-simulator-playback.mjs",
    "webos:debug:player": "node ./scripts/webos-debug-player.mjs",
    "webos:debug:player:macos": "node ./scripts/webos-debug-player.macos.mjs",
    "webos:debug:player:windows": "node ./scripts/webos-debug-player.windows.mjs",
    "webos:doctor": "node ./scripts/webos-cli.mjs doctor",
    "webos:package": "npm run build:webos && node ./scripts/webos-cli.mjs package",
    "webos:install": "node ./scripts/webos-cli.mjs install",
    "webos:update": "node ./scripts/webos-cli.mjs update",
    "webos:reinstall": "node ./scripts/webos-cli.mjs reinstall",
    "webos:verify-install": "node ./scripts/webos-cli.mjs verify-installed-entry",
    "webos:deploy": "npm run build:webos && node ./scripts/webos-cli.mjs deploy",
    "webos:launch": "node ./scripts/webos-cli.mjs launch",
    "webos:list": "node ./scripts/webos-cli.mjs list",
    "webos:remove": "node ./scripts/webos-cli.mjs remove",
    "webos:hosted": "npm run build:webos && node ./scripts/webos-cli.mjs hosted",
    "webos:simulator": "npm run build:webos && node ./scripts/webos-cli.mjs simulator"
  },
  "dependencies": {
    "js-md5": "^0.8.3",
    "material-symbols": "^0.42.3",
    "qrcode": "^1.5.4",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "shaka-player": "^5.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.34.0",
    "@types/node": "^24.3.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-legacy": "^7.2.1",
    "@vitejs/plugin-react": "^5.0.2",
    "eslint": "^9.34.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "fast-glob": "^3.3.3",
    "globals": "^16.3.0",
    "jsdom": "^29.0.1",
    "subset-font": "^2.4.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.41.0",
    "vite": "^7.1.3",
    "vitest": "^4.1.0"
  }
}
