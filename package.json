{
  "name": "bilibili-webos",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:webos": "npm run build && node ./scripts/prepare-webos.mjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "webos:doctor": "node ./scripts/webos-cli.mjs doctor",
    "webos:package": "npm run build:webos && node ./scripts/webos-cli.mjs package",
    "webos:install": "node ./scripts/webos-cli.mjs install",
    "webos:launch": "node ./scripts/webos-cli.mjs launch",
    "webos:list": "node ./scripts/webos-cli.mjs list",
    "webos:remove": "node ./scripts/webos-cli.mjs remove",
    "webos:hosted": "npm run build:webos && node ./scripts/webos-cli.mjs hosted"
  },
  "dependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.34.0",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "eslint": "^9.34.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.41.0",
    "vite": "^7.1.3"
  }
}
